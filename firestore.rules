rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isApprovedProvider() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'provider' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.providerStatus == 'approved';
    }

    function isChatParticipant(chatId) {
      let parts = chatId.split('_');
      return parts.size() == 2 &&
        (parts[0] == request.auth.uid || parts[1] == request.auth.uid);
    }

    function isTargetInChat(chatId, targetUid) {
      let parts = chatId.split('_');
      return parts.size() == 2 &&
        (parts[0] == targetUid || parts[1] == targetUid);
    }

    function isBookingParticipant(bookingId, uid) {
      let booking = get(/databases/$(database)/documents/bookings/$(bookingId)).data;
      return booking.customerId == uid || booking.providerId == uid;
    }

    match /users/{userId} {
      allow get, list: if isAuthenticated() && (isUser(userId) || isAdmin());
      allow create: if isAuthenticated() &&
        isUser(userId) &&
        request.resource.data.uid == userId &&
        request.resource.data.role in ['customer', 'admin'];
      allow update: if isAuthenticated() && (isUser(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /provider_applications/{appId} {
      allow get, list: if isAuthenticated() &&
        (resource == null ||
         resource.data.status == 'approved' ||
         isUser(appId) ||
         isAdmin());

      allow create: if isAuthenticated() &&
        isUser(appId) &&
        request.resource.data.userId == appId &&
        request.resource.data.status == 'pending';

      allow update: if isAuthenticated() &&
        (
          (isUser(appId) && resource.data.status == 'pending') ||
          isAdmin() ||
          (
            isUser(appId) &&
            resource.data.status == 'approved' &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['businessImages', 'updatedAt'])
          )
        );

      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow create: if isAuthenticated() &&
        request.resource.data.customerId == request.auth.uid;

      allow get, list: if isAuthenticated() &&
        (resource.data.customerId == request.auth.uid ||
         resource.data.providerId == request.auth.uid ||
         isAdmin());

      allow update: if isAuthenticated() && (
        isAdmin() ||
        (
          resource.data.providerId == request.auth.uid &&
          request.resource.data.customerId == resource.data.customerId &&
          request.resource.data.providerId == resource.data.providerId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
        ) ||
        (
          resource.data.customerId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['customerConfirmation', 'customerConfirmedAt', 'uncompletedReason', 'updatedAt', 'paymentStatus', 'paidAmount', 'paidAt'])
        )
      );

      allow delete: if isAdmin();
    }

    match /saved_services/{savedId} {
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow get, list: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid ||
        isAdmin() ||
        (
          request.resource.data.type == 'booking' &&
          request.resource.data.data.bookingId is string &&
          isBookingParticipant(request.resource.data.data.bookingId, request.auth.uid) &&
          isBookingParticipant(request.resource.data.data.bookingId, request.resource.data.userId)
        ) ||
        (
          request.resource.data.type == 'chat' &&
          request.resource.data.data.chatId is string &&
          isChatParticipant(request.resource.data.data.chatId) &&
          isTargetInChat(request.resource.data.data.chatId, request.resource.data.userId)
        ) ||
        (
          request.resource.data.type == 'review' &&
          request.resource.data.data.bookingId is string &&
          isBookingParticipant(request.resource.data.data.bookingId, request.auth.uid) &&
          isBookingParticipant(request.resource.data.data.bookingId, request.resource.data.userId)
        )
      );
      allow get, list: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == resource.data.userId;
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    match /payments/{paymentId} {
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow get, list: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /withdrawal_requests/{withdrawalId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow get, list: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /wallets/{walletUserId} {
      allow create: if isAuthenticated() && isUser(walletUserId);
      allow get, list: if isAuthenticated() && (isUser(walletUserId) || isAdmin());
      allow update: if isAuthenticated() &&
        (isUser(walletUserId) || isAdmin()) &&
        request.resource.data.userId == resource.data.userId;
      allow delete: if isAdmin();

      match /transactions/{transactionId} {
        allow create: if isAuthenticated() &&
          request.resource.data.userId == request.auth.uid &&
          isUser(walletUserId);
        allow get, list: if isAuthenticated() &&
          (isUser(walletUserId) || isAdmin());
        allow update, delete: if isAdmin();
      }
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && (
        isChatParticipant(chatId) ||
        request.auth.uid in resource.data.participants
      );
      allow create: if isAuthenticated() && isChatParticipant(chatId);
      allow update: if isAuthenticated() &&
        isChatParticipant(chatId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'participants', 'lastMessage', 'lastMessageTime', 'updatedAt'
        ]);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAuthenticated() && (
          isChatParticipant(chatId) ||
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
        );
        allow create: if isAuthenticated() && (
          isChatParticipant(chatId) ||
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
        );

        allow create: if request.resource.data.senderId == request.auth.uid &&
          request.resource.data.message is string &&
          request.resource.data.message.size() > 0;

        allow update, delete: if false;
      }
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /app_settings/{settingId} {
      allow get, list: if isAuthenticated() && isAdmin();
      allow create, update, delete: if isAuthenticated() && isAdmin();
    }

    match /reviews/{reviewId} {
      allow create: if isAuthenticated() &&
        request.resource.data.customerId == request.auth.uid &&
        request.resource.data.bookingId is string &&
        get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.customerId == request.auth.uid &&
        get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.providerId == request.resource.data.providerId &&
        (
          get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.status == 'confirmed' ||
          get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.status == 'completed'
        );
      allow get, list: if isAuthenticated() &&
        (
          resource.data.providerId == request.auth.uid ||
          resource.data.customerId == request.auth.uid ||
          isAdmin()
        );
      allow update, delete: if isAuthenticated() &&
        (resource.data.customerId == request.auth.uid || isAdmin());
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create: if isApprovedProvider();
      allow update, delete: if isAuthenticated() &&
        (resource.data.providerId == request.auth.uid || isAdmin());
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}